HOST=0.0.0.0
PORT=8090
ENVIRONMENT=local

# PostgreSQL
DATABASE_URL=jdbc:postgresql://<host>/<database>?sslmode=require&channel_binding=require
DATABASE_USER=<database-user>
DATABASE_PASSWORD=<database-password>
RUN_MIGRATIONS=true

# Firebase Auth
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app

# Media storage: use cloudinary for pilot uploads without Firebase Storage billing.
MEDIA_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# GSTIN lookup provider
GSTINCHECK_API_KEY=your-gstincheck-api-key
GSTINCHECK_BASE_URL=https://sheet.gstincheck.co.in/check

# Comma-separated origins. Use * only for local development.
ALLOWED_ORIGINS=http://localhost:8090,http://localhost:8081,http://localhost:3000,https://orma-web-dun.vercel.app
